generator client {
    provider             = "prisma-client-py"
    interface            = "asyncio"
    recursive_type_depth = 5
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Post {
    id           String    @id @default(uuid())
    content      String
    likes        Int       @default(0)
    published_at DateTime?
    created_at   DateTime  @default(now())
    updated_at   DateTime  @updatedAt
}
